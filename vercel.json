{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "require-corp"
        }
      ]
    }
  ],
  "functions": {
    "src/app/api/transcribe-whisper/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/analyze-modes/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/search-broll/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/proxy-video/route.ts": {
      "maxDuration": 60
    }
  }
}
